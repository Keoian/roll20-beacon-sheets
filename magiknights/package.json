{
  "name": "@r20sd/quickstart-example-sheet",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sandbox-server": "vite --port 7620 --mode staging",
    "sandbox": "run-s build-scss sandbox-server",
    "build": "run-s build-scss && vite build",
    "build:discord": "run-s build-scss && vite build --config vite.discord.config.js",
    "build-scss": "sass ./src/rollTemplates/styles/host.scss ./public/host.css --no-source-map --no-charset",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@roll20-official/beacon-sdk": "^0.1.15",
    "handlebars": "^4.7.8",
    "jsonpath": "^1.1.1",
    "lodash": "^4.17.21",
    "pinia": "^2.1.7",
    "uuid": "^9.0.1",
    "vue": "^3.4.21",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.1",
    "sass": "^1.75.0",
    "vite": "^5.2.8",
    "vite-plugin-vue-devtools": "^7.0.25",
    "vitest": "^1.6.0"
  }
}
